# Supabase — find these in the Supabase dashboard under Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-side only; never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# API key for /api/mcp/* routes and the MCP server
# Generate any strong random string, e.g.: openssl rand -hex 32
ARTIFACT_HUB_ADMIN_KEY=your-admin-key

# Gemini API key for feedback summarization
# Get from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key

# Gemini model to use (defaults to gemini-2.5-flash if unset)
GEMINI_MODEL=gemini-2.5-flash

# Base URL of the deployed Next.js app — used by the MCP server to call /api/mcp/*
# Local dev: http://localhost:3000  |  Production: https://your-app.vercel.app
ARTIFACT_HUB_BASE_URL=https://your-app.vercel.app
