# Supabase — find these in the Supabase dashboard under Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-side only; never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# API key for /api/mcp/* routes and the MCP server
# Generate any strong random string, e.g.: openssl rand -hex 32
ARTIFACT_HUB_ADMIN_KEY=your-admin-key

# Anthropic API key for feedback summarization
ANTHROPIC_API_KEY=your-anthropic-key
